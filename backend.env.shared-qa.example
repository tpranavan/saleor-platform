# Shared QA Postgres + Redis for local Saleor (via SSH tunnel on host :5432 / :6379).
# Generate from QA credentials: ./scripts/setup-shared-qa-env.sh
#
# Requires: ./scripts/shared-qa-tunnel.sh start

DATABASE_URL=postgresql://boto_qa:PASSWORD@host.docker.internal:5432/boto_qa
CACHE_URL=redis://host.docker.internal:6379/1
CELERY_BROKER_URL=redis://host.docker.internal:6379/2

# Match QA Cloud Run secrets when using the shared boto_qa database.
SECRET_KEY=match-boto-saleor-secret-key-from-secret-manager

DEFAULT_FROM_EMAIL=noreply@example.com
EMAIL_URL=smtp://mailpit:1025
OTEL_SERVICE_NAME=saleor
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
